# Copy this file to .env and fill in at least one key.
# .env is gitignored — never commit real keys.
#
# Use Anthropic (Claude) — https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=your_api_key_here
#
# OR use OpenAI (ChatGPT) — https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_api_key_here
